@page
@model IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>EAHSA Login</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="login-page">>

<div class="login-container">
    <img src="~/images/logo.png" alt="School Logo" class="logo" />

    <h2>Welcome Back</h2>
    <p>Sign in to your account</p>

    <form method="post">
        <!-- Bind to PageModel -->
        <input asp-for="Email" type="email" placeholder="Email Address" required />
        <input asp-for="Password" type="password" placeholder="Password" required />

        <button type="submit">Sign In</button>
    </form>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <p style="color:red">@Model.ErrorMessage</p>
    }
</div>

<i class="bi bi-speedometer2"></i> Dashboard
<i class="bi bi-calendar-check"></i> Attendance
<i class="bi bi-person-badge"></i> ID Management
<i class="bi bi-person-plus"></i> Register User

</body>
</html>