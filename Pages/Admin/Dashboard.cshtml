@page
@model DashboardModel
@{
    Layout = "_AdminLayout";
}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="dashboard">

<h1>Attendance Dashboard</h1>

<div class="cards">

<div class="row g-4">

<div class="col-md-4">
<div class="card shadow dashboard-card">
<div class="card-body">

<h6 class="text-muted">TOTAL STUDENTS</h6>
<h2>@Model.TotalStudents</h2>

</div>
</div>
</div>

<div class="col-md-4">
<div class="card shadow dashboard-card">
<div class="card-body">

<h6 class="text-success">PRESENT TODAY</h6>
<h2>@Model.PresentToday</h2>

</div>
</div>
</div>

<div class="col-md-4">
<div class="card shadow dashboard-card">
<div class="card-body">

<h6 class="text-danger">ABSENT TODAY</h6>
<h2>@Model.AbsentToday</h2>


</div>
</div>
</div>
</div>

</div>

<div class="charts">

<div class="chart-box">
<h3>Absence Trends</h3>
<canvas id="absenceChart"></canvas>
</div>

<div class="recent">

<h5>🟡 Today’s Absent Students</h5>

<div style="max-height:300px; overflow-y:auto;">

<table class="table table-hover align-middle">

<thead>
<tr>
    <th>Name</th>
    <th>Grade</th>
    <th>Status</th>
</tr>
</thead>

<tbody>

@foreach(var item in Model.RecentAbsences)
{
<tr>
    <td><strong>@item.Name</strong></td>
    <td>@item.Grade</td>
    <td>
        <span class="badge bg-danger">
            @item.Status
        </span>
    </td>
</tr>
}

</tbody>

</table>

</div>

</div>
</div>

<script>

var ctx = document.getElementById('absenceChart').getContext('2d');

new Chart(ctx, {
    type: 'bar',
    data: {
        labels: @Html.Raw(Json.Serialize(Model.ChartLabels)),
        datasets: [{
            label: 'Absences',
            data: @Html.Raw(Json.Serialize(Model.ChartData)),
            backgroundColor: 'rgba(255, 99, 132, 0.6)',
            borderRadius: 8
        }]
    },
    options: {
        responsive: true,
        plugins: {
            legend: { display: false }
        },
        scales: {
            y: {
                beginAtZero: true,
                ticks: {
                    stepSize: 1
                }
            }
        }
    }
});

</script>